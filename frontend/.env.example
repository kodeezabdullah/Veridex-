# Public URL used by browser requests. Leave empty for same-origin API routes.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8010

# Absolute backend origin required by Next.js server components.
VERIDEX_API_BASE_URL=http://127.0.0.1:8010

# Mapbox access token for map tiles (https://account.mapbox.com)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_token_here
